# Supabase (Capítulo 21) — Auth + PostgreSQL
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vestigial: the CRM used to be a separate app on crm.teamnexus.com.br and
# this enabled a shared-cookie SSO between the two. The CRM is now merged
# into this app at /portal (single origin, single session) — leave EMPTY.
NEXT_PUBLIC_COOKIE_DOMAIN=

# Vestigial: was meant to point at a future CRM-hosted read API for the
# public Portfolio pages (Capítulo 25). The CRM is now merged into this app
# instead of being a separate API host, so this is unlikely to ever be set —
# see src/services/portfolio/get-projects.ts for the local-fallback logic.
NEXT_PUBLIC_CRM_API_URL=

# --- Portal (merged CRM — Nexus Prospect System, src/app/portal) ---
# SUPABASE_SERVICE_ROLE_KEY is already declared above (Supabase section) —
# it's the Portal's webhook/admin routes that actually consume it, via
# createServiceClient() in src/services/supabase/server.ts.
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APIFY_API_TOKEN=
EVOLUTION_WEBHOOK_SECRET=
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_BUSINESS_ACCOUNT_ID=
WHATSAPP_CLOUD_APP_SECRET=
WHATSAPP_CLOUD_VERIFY_TOKEN=
CAMPAIGN_DISPATCH_SECRET=
