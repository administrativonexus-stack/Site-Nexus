# Supabase (Capítulo 21) — Auth + PostgreSQL
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cross-subdomain SSO with the CRM (crm.teamnexus.com.br) — leave EMPTY for
# local dev and Preview deployments (a page can't set a cookie for a domain
# that doesn't match its own host). Only set to .teamnexus.com.br in
# Vercel's Production environment, once both apps are live on that domain.
NEXT_PUBLIC_COOKIE_DOMAIN=

# CRM API (Capítulo 25) — leave empty until the external CRM's read API
# exists; the site falls back to local placeholder project data until then.
# See src/services/portfolio/get-projects.ts for the expected contract.
NEXT_PUBLIC_CRM_API_URL=
